{
    "name": "elonphp/laravel-ocadmin-modules",
    "description": "Modular Laravel admin panel framework",
    "type": "library",
    "license": "proprietary",
    "authors": [
        {
            "name": "Elon Chen",
            "email": "elon@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "spatie/laravel-permission": "^6.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Elonphp\\LaravelOcadminModules\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Elonphp\\LaravelOcadminModules\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Elonphp\\LaravelOcadminModules\\Core\\Providers\\OcadminServiceProvider"
            ],
            "aliases": {
                "Ocadmin": "Elonphp\\LaravelOcadminModules\\Facades\\Ocadmin"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
